# Arquivo de configuração de ambiente de exemplo

# Chave secreta para assinatura dos tokens JWT.
# Gere uma chave segura em produção (ex: openssl rand -hex 32)
JWT_SECRET=super_secret_key_change_in_production

# Ambiente da aplicação (development | production)
ENV=production

# Porta que o backend vai rodar internamente no container
PORT=8080
